{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "devCommand": "live-server --port=3000",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat.js"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  }
}
